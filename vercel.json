{
  "crons": [
    {
      "path": "/api/cron/every-15min",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-morning",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-evening",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/twice-weekly",
      "schedule": "0 12 * * 2,5"
    }
  ]
}
